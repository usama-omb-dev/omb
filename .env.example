# =============================================================================
# OMB Forms (WordPress) + Next.js — copy to `.env.local` and fill in values.
#   cp .env.example .env.local
# WordPress: set the same submit secret in wp-config.php (see below).
# =============================================================================

# Base URL of the WordPress site (no trailing slash). Used for CF7 and OMB Forms.
WORDPRESS_ORIGIN=https://backend.onlinemarketingbakery.nl

# --- OMB Form Builder (headless) ------------------------------------------------
# Comma-separated extra form post IDs (optional). Contact/sidebar *_FORM_ID vars are
# always merged in — you do not need to repeat those IDs here.
OMB_FORM_BUILDER_ALLOWED_IDS=225,227

# Optional extra slugs (comma-separated). Contact/sidebar *_FORM_SLUG vars are merged in.
OMB_FORM_BUILDER_ALLOWED_SLUGS=

# Must match WordPress: define( 'CFB_HEADLESS_SUBMIT_SECRET', '...' );
OMB_FORM_BUILDER_SUBMIT_SECRET=d9f4c8a7b2e16f0c3a95e8471bd62c5f4a0e9c13b7d8f62a1c5e4b9d0f3a7c6e

# Contact page: use OMB form when one of these is set (ID wins if both set).
OMB_FORM_BUILDER_CONTACT_FORM_ID=225
OMB_FORM_BUILDER_CONTACT_FORM_SLUG=

# Blog single + case study sidebar (“Plan a call”): OMB form when set; else CF7 ScheduleCallForm.
# Shared default for both templates (optional):
OMB_FORM_BUILDER_SIDEBAR_FORM_ID=227
OMB_FORM_BUILDER_SIDEBAR_FORM_SLUG=
# Per-template overrides (optional):
OMB_FORM_BUILDER_BLOG_SIDEBAR_FORM_ID=227
OMB_FORM_BUILDER_BLOG_SIDEBAR_FORM_SLUG=
OMB_FORM_BUILDER_CASE_STUDY_SIDEBAR_FORM_ID=227
OMB_FORM_BUILDER_CASE_STUDY_SIDEBAR_FORM_SLUG=

# Optional default when you add more pages later
# OMB_FORM_BUILDER_DEFAULT_ID=

# --- Contact Form 7 (existing site forms) ------------------------------------
# CONTACT_FORM_7_ALLOWED_IDS=
# CONTACT_FORM_7_DEFAULT_ID=
